@page
@model KakeiboApp.Pages.BillingHistoryModel
@{
    ViewData["Title"] = "翌月払い確認";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>翌月払い確認</title>
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'メイリオ', sans-serif;
                background: #f0f2f8;
                color: #333;
                padding-bottom: 20px;
            }

            .header {
                background: #2a3c78;
                color: white;
                padding: 12px 15px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 100;
            }

            .header-title {
                font-size: 18px;
                font-weight: bold;
                flex-shrink: 0;
            }

            .header-nav {
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .nav-link {
                color: white;
                text-decoration: none;
                padding: 5px 8px;
                border-radius: 6px;
                font-size: 12px;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 2px;
                flex-shrink: 0;
            }

                .nav-link:hover {
                    background: rgba(255,255,255,0.15);
                }

                .nav-link span {
                    font-size: 16px;
                }

                .nav-link small {
                    font-size: 9px;
                }

            .month-nav {
                background: white;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 15px;
                padding: 10px;
                border-bottom: 1px solid #eee;
            }

                .month-nav button {
                    background: #2a3c78;
                    border: none;
                    color: white;
                    padding: 5px 14px;
                    border-radius: 6px;
                    cursor: pointer;
                    font-size: 15px;
                }

                .month-nav span {
                    font-size: 16px;
                    font-weight: bold;
                    color: #2a3c78;
                }

            .container {
                padding: 15px;
                max-width: 600px;
                margin: 0 auto;
            }

            .total-card {
                background: #2a3c78;
                color: white;
                border-radius: 10px;
                padding: 20px;
                margin-bottom: 15px;
                text-align: center;
                box-shadow: 0 2px 6px rgba(0,0,0,0.15);
            }

                .total-card .label {
                    font-size: 13px;
                    opacity: 0.8;
                    margin-bottom: 8px;
                }

                .total-card .amount {
                    font-size: 28px;
                    font-weight: bold;
                }

            .section {
                background: white;
                border-radius: 10px;
                padding: 15px;
                margin-bottom: 15px;
                box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            }

                .section h3 {
                    font-size: 14px;
                    color: #2a3c78;
                    margin-bottom: 10px;
                }

            .transaction-item {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 0;
                border-bottom: 1px solid #f0f0f0;
            }

                .transaction-item:last-child {
                    border-bottom: none;
                }

            .t-left .t-name {
                font-size: 14px;
                font-weight: bold;
            }

            .t-left .t-meta {
                font-size: 11px;
                color: gray;
                margin-top: 2px;
            }

            .t-amount {
                font-size: 15px;
                font-weight: bold;
                color: #dc4646;
            }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-title">💳 翌月払い確認</div>
        <div class="header-nav">
            <a href="/" class="nav-link"><span>🏠</span><small>ホーム</small></a>
            <a href="/Report" class="nav-link"><span>📊</span><small>レポート</small></a>
            <a href="/Settings" class="nav-link"><span>⚙️</span><small>設定</small></a>
        </div>
    </div>

    <div class="month-nav">
        <button onclick="changeMonth(-1)">◀</button>
        <span>@Model.Year 年 @Model.Month 月 の利用分</span>
        <button onclick="changeMonth(1)">▶</button>
    </div>

    <div class="container">
        <div class="total-card">
            <div class="label">@Model.Year 年 @Model.Month 月 の翌月払い合計</div>
            <div class="amount">¥@Model.TotalAmount.ToString("#,0")</div>
        </div>

        <div class="section">
            <h3>💳 翌月払い一覧（カード・QR・電子マネー）</h3>
            @if (!Model.Transactions.Any())
            {
                <p style="color:gray;font-size:13px">翌月払いの取引はありません</p>
            }
            @foreach (var t in Model.Transactions)
            {
                var cat = Model.GetCategory(t.CategoryId);
                <div class="transaction-item">
                    <div class="t-left">
                        <div class="t-name">@cat?.Icon @(string.IsNullOrEmpty(t.Note) ? cat?.Name : t.Note)</div>
                        <div class="t-meta">@t.Date.ToString("M/d") ・ @Model.GetPaymentLabel(t.PaymentMethod)</div>
                    </div>
                    <div class="t-amount">-¥@t.Amount.ToString("#,0")</div>
                </div>
            }
        </div>
    </div>

    <script>
            function changeMonth(delta) {
                const url   = new URL(window.location.href);
                let year    = parseInt(url.searchParams.get('year')  || '@Model.Year');
                let month   = parseInt(url.searchParams.get('month') || '@Model.Month');
                month += delta;
                if (month > 12) { month = 1; year++; }
                if (month < 1)  { month = 12; year--; }
                url.searchParams.set('year',  year);
                url.searchParams.set('month', month);
                window.location.href = url.toString();
            }
    </script>
</body>
</html>