@page
@using KakeiboApp.Models
@model KakeiboApp.Pages.EditFixedModel
@{
    ViewData["Title"] = "固定費編集";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>固定費編集</title>
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'メイリオ', sans-serif;
                background: #f0f2f8;
                color: #333;
                padding-bottom: 20px;
            }

            .header {
                background: #2a3c78;
                color: white;
                padding: 12px 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .header-title {
                font-size: 18px;
                font-weight: bold;
            }

            .header-nav {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .nav-link {
                color: white;
                text-decoration: none;
                padding: 6px 12px;
                border-radius: 6px;
                font-size: 13px;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 2px;
            }

                .nav-link span {
                    font-size: 18px;
                }

                .nav-link small {
                    font-size: 10px;
                }

            .btn-back {
                color: white;
                text-decoration: none;
                padding: 6px 12px;
                border-radius: 6px;
                font-size: 13px;
                background: rgba(255,255,255,0.15);
            }

            .container {
                padding: 15px;
                max-width: 600px;
                margin: 0 auto;
            }

            .card {
                background: white;
                border-radius: 10px;
                padding: 20px;
                margin-top: 15px;
                box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            }

                .card h3 {
                    font-size: 16px;
                    color: #2a3c78;
                    margin-bottom: 20px;
                }

            .form-group {
                margin-bottom: 15px;
            }

                .form-group label {
                    display: block;
                    font-size: 12px;
                    font-weight: bold;
                    color: gray;
                    margin-bottom: 6px;
                }

                .form-group input, .form-group select {
                    width: 100%;
                    padding: 10px;
                    border: 1px solid #ddd;
                    border-radius: 8px;
                    font-size: 14px;
                }

            .btn-row {
                display: flex;
                gap: 10px;
                margin-top: 15px;
            }

            .btn-save {
                flex: 1;
                padding: 14px;
                background: #2a3c78;
                color: white;
                border: none;
                border-radius: 10px;
                font-size: 15px;
                font-weight: bold;
                cursor: pointer;
            }

            .btn-delete {
                flex: 1;
                padding: 14px;
                background: #dc4646;
                color: white;
                border: none;
                border-radius: 10px;
                font-size: 15px;
                font-weight: bold;
                cursor: pointer;
            }

            .banner {
                display: none;
                position: fixed;
                top: 70px;
                left: 50%;
                transform: translateX(-50%);
                background: #3c9660;
                color: white;
                padding: 12px 24px;
                border-radius: 8px;
                font-size: 14px;
                font-weight: bold;
                z-index: 999;
            }
    </style>
</head>
<body>
    <div id="banner" class="banner"></div>

    <div class="header">
        <div style="display:flex;align-items:center;gap:10px">
            <a href="/Settings" class="btn-back">← 戻る</a>
            <div class="header-title">🔁 固定費編集</div>
        </div>
        <div class="header-nav">
            <a href="/" class="nav-link"><span>🏠</span><small>ホーム</small></a>
            <a href="/Report" class="nav-link"><span>📊</span><small>レポート</small></a>
            <a href="/Settings" class="nav-link"><span>⚙️</span><small>設定</small></a>
        </div>
    </div>

    <div class="container">
        @if (Model.Fixed == null)
        {
            <p style="color:red;padding:20px">固定費が見つかりませんでした。</p>
        }
        else
        {
            <div class="card">
                <h3>🔁 @Model.Fixed.Name を編集</h3>
                <div class="form-group">
                    <label>固定費名</label>
                    <input type="text" id="fixedName" value="@Model.Fixed.Name" />
                </div>
                <div class="form-group">
                    <label>金額（円）</label>
                    <input type="number" id="fixedAmount" value="@Model.Fixed.Amount" />
                </div>
                <div class="form-group">
                    <label>毎月何日に計上</label>
                    <input type="number" id="fixedDay" value="@Model.Fixed.DayOfMonth" min="1" max="31" />
                </div>
                <div class="form-group">
                    <label>カテゴリ</label>
                    <select id="fixedCategory">
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.Id">@c.Icon @c.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>支払い方法</label>
                    <select id="fixedPayment">
                        <option value="Cash">💵 現金</option>
                        <option value="Card">💳 カード</option>
                        <option value="ElectronicMoney">📲 電子マネー</option>
                        <option value="QRPayment">📱 QR決済</option>
                        <option value="BankAccount">🏦 口座</option>
                    </select>
                </div>
                <div class="btn-row">
                    <button class="btn-save" onclick="save('@Model.Fixed.Id')">💾 更新する</button>
                    <button class="btn-delete" onclick="deleteFixed('@Model.Fixed.Id', '@Model.Fixed.Name')">🗑 削除する</button>
                </div>
            </div>
        }
    </div>

    <script>
            // 初期値をセット
            document.getElementById('fixedCategory').value = '@Model.Fixed?.CategoryId';
            document.getElementById('fixedPayment').value  = '@Model.Fixed?.PaymentMethod';

            function showBanner(message) {
                const banner = document.getElementById('banner');
                banner.textContent   = message;
                banner.style.display = 'block';
                setTimeout(() => banner.style.display = 'none', 2000);
            }

            async function save(id) {
                const name       = document.getElementById('fixedName').value.trim();
                const amount     = parseInt(document.getElementById('fixedAmount').value);
                const day        = parseInt(document.getElementById('fixedDay').value);
                const categoryId = document.getElementById('fixedCategory').value;
                const payment    = document.getElementById('fixedPayment').value;
                if (!name || !amount || !day) { alert('全項目を入力してください'); return; }

                const res  = await fetch(`/api/kakeibo/fixed/${id}`, {
                    method  : 'PUT',
                    headers : { 'Content-Type': 'application/json' },
                    body    : JSON.stringify({ name, amount, dayOfMonth: day, categoryId, paymentMethod: payment })
                });
                const json = await res.json();
                if (res.ok) {
                    showBanner(json.message);
                    setTimeout(() => window.location.href = '/Settings', 1000);
                } else {
                    alert('更新に失敗しました');
                }
            }

            async function deleteFixed(id, name) {
                if (!confirm(`「${name}」を削除してもよいですか？\nこの操作は元に戻せません。`)) return;

                const res  = await fetch(`/api/kakeibo/fixed/${id}`, { method: 'DELETE' });
                const json = await res.json();
                if (res.ok) {
                    showBanner(json.message);
                    setTimeout(() => window.location.href = '/Settings', 1000);
                } else {
                    alert('削除に失敗しました');
                }
            }
    </script>
</body>
</html>