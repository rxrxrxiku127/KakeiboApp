@page
@model KakeiboApp.Pages.ReportModel
@{
    ViewData["Title"] = "レポート";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>レポート</title>
    @* Chart.jsをCDNから読み込む *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
        * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        }

        body {
        font-family: 'メイリオ', sans-serif;
        background: #f0f2f8;
        color: #333;
        padding-bottom: 20px;
        }

        .header {
        background: #2a3c78;
        color: white;
        padding: 12px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        }

        .header-title {
        font-size: 18px;
        font-weight: bold;
        }

        .header-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        }

        .nav-link {
        color: white;
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        }

        .nav-link:hover {
        background: rgba(255,255,255,0.15);
        }

        .nav-link.active {
        background: rgba(255,255,255,0.25);
        }

        .nav-link span {
        font-size: 18px;
        }

        .nav-link small {
        font-size: 10px;
        }

        .month-nav {
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        padding: 10px;
        border-bottom: 1px solid #eee;
        }

        .month-nav button {
        background: #2a3c78;
        border: none;
        color: white;
        padding: 5px 14px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 15px;
        }

        .month-nav span {
        font-size: 16px;
        font-weight: bold;
        color: #2a3c78;
        }

        .container {
        padding: 15px;
        max-width: 600px;
        margin: 0 auto;
        }

        .card {
        background: white;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        }

        .card h3 {
        font-size: 14px;
        color: #2a3c78;
        margin-bottom: 15px;
        }

        .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #f0f0f0;
        font-size: 14px;
        }

        .summary-row:last-child {
        border-bottom: none;
        }

        .income {
        color: #3c9660;
        font-weight: bold;
        }

        .expense {
        color: #dc4646;
        font-weight: bold;
        }

        .balance {
        color: #2a3c78;
        font-weight: bold;
        }

        .bar-wrap {
        margin: 8px 0;
        }

        .bar-label {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        margin-bottom: 3px;
        }

        .progress {
        background: #eee;
        border-radius: 6px;
        height: 12px;
        }

        .progress-bar {
        height: 12px;
        border-radius: 6px;
        background: #4682dc;
        }
    </style>
</head>
<body>

    @*
    =====================================================
    共通ヘッダー
    =====================================================
    *@
    <div class="header">
        <div class="header-title">📊 レポート</div>
        <div class="header-nav">
            <a href="/" class="nav-link"><span>🏠</span><small>ホーム</small></a>
            <a href="/Report" class="nav-link active"><span>📊</span><small>レポート</small></a>
            <a href="/Settings" class="nav-link"><span>⚙️</span><small>設定</small></a>
        </div>
    </div>

    @* 月ナビゲーション *@
    <div class="month-nav">
        <button onclick="changeMonth(-1)">◀</button>
        <span>@Model.Year 年 @Model.Month 月</span>
        <button onclick="changeMonth(1)">▶</button>
    </div>

    <div class="container">

        @*
        =====================================================
        収支サマリー
        =====================================================
        *@
        <div class="card">
            <h3>💴 収支サマリー</h3>
            <div class="summary-row">
                <span>収入</span>
                <span class="income">¥@Model.TotalIncome.ToString("#,0")</span>
            </div>
            <div class="summary-row">
                <span>支出</span>
                <span class="expense">¥@Model.TotalExpense.ToString("#,0")</span>
            </div>
            <div class="summary-row">
                <span>残高</span>
                <span class="balance">¥@Model.Balance.ToString("#,0")</span>
            </div>
        </div>

        @*
        =====================================================
        カテゴリ別支出（円グラフ）
        Chart.jsのdoughnutチャートで表示
        =====================================================
        *@
        <div class="card">
            <h3>🥧 カテゴリ別支出</h3>
            <canvas id="pieChart" height="200"></canvas>
        </div>

        @*
        =====================================================
        カテゴリ別詳細（プログレスバー）
        予算上限に対する使用率を表示
        =====================================================
        *@
        <div class="card">
            <h3>📊 カテゴリ別詳細</h3>
            @foreach (var b in Model.BudgetItems)
            {
                var pct = Math.Min(b.Percent, 100);
                <div class="bar-wrap">
                    <div class="bar-label">
                        <span>@b.Icon @b.Name</span>
                        <span>¥@b.Used.ToString("#,0") @(b.Limit > 0 ? $"/ ¥{b.Limit:#,0}" : "")</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar" style="width:@pct%"></div>
                    </div>
                </div>
            }
        </div>

        @*
        =====================================================
        支払い方法別支出（棒グラフ）
        =====================================================
        *@
        <div class="card">
            <h3>💳 支払い方法別</h3>
            <canvas id="payChart" height="150"></canvas>
        </div>
    </div>

    <script>
        // =====================================================
        // 円グラフ（カテゴリ別支出）
        // Chart.jsのdoughnutタイプを使用
        // =====================================================
        const pieData = @Html.Raw(Model.PieChartJson);
        new Chart(document.getElementById('pieChart'), {
        type: 'doughnut',
        data: {
        labels   : pieData.map(d => d.name),
        datasets : [{
        data            : pieData.map(d => d.amount),
        backgroundColor : [
        '#4682dc','#3c9660','#dc4646','#ffc107',
        '#9c27b0','#ff5722','#00bcd4','#795548',
        '#607d8b','#e91e63'
        ]
        }]
        },
        options: { plugins: { legend: { position: 'bottom' } } }
        });

        // =====================================================
        // 棒グラフ（支払い方法別支出）
        // =====================================================
        const payData = @Html.Raw(Model.PayChartJson);
        new Chart(document.getElementById('payChart'), {
        type: 'bar',
        data: {
        labels   : payData.map(d => d.name),
        datasets : [{
        label           : '支出',
        data            : payData.map(d => d.amount),
        backgroundColor : '#4682dc'
        }]
        },
        options: {
        plugins : { legend: { display: false } },
        scales  : { y: { beginAtZero: true } }
        }
        });

        // =====================================================
        // changeMonth(delta)
        // 月ナビゲーションで前月・翌月に切り替える
        // =====================================================
        function changeMonth(delta) {
        const url = new URL(window.location.href);
        let year  = parseInt(url.searchParams.get('year')  || '@Model.Year');
        let month = parseInt(url.searchParams.get('month') || '@Model.Month');
        month += delta;
        if (month > 12) { month = 1; year++; }
        if (month < 1)  { month = 12; year--; }
        url.searchParams.set('year',  year);
        url.searchParams.set('month', month);
        window.location.href = url.toString();
        }
    </script>
</body>
</html>