@page
@model KakeiboApp.Pages.ChangePasswordModel
@{
    ViewData["Title"] = "パスワード変更";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>パスワード変更</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'メイリオ', sans-serif; background: #f0f2f8; color: #333; padding-bottom: 20px; }
        .header { background: #2a3c78; color: white; padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; }
        .header-title { font-size: 18px; font-weight: bold; }
        .header-nav { display: flex; align-items: center; gap: 8px; }
        .nav-link { color: white; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; display: flex; flex-direction: column; align-items: center; gap: 2px; }
        .nav-link span { font-size: 18px; }
        .nav-link small { font-size: 10px; }
        .btn-back { color: white; text-decoration: none; padding: 6px 12px; border-radius: 6px; font-size: 13px; background: rgba(255,255,255,0.15); }
        .container { padding: 15px; max-width: 600px; margin: 0 auto; }
        .card { background: white; border-radius: 10px; padding: 20px; margin-top: 15px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
        .card h3 { font-size: 16px; color: #2a3c78; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; font-size: 12px; font-weight: bold; color: gray; margin-bottom: 6px; }
        .form-group input { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; }
        .btn-save { width: 100%; padding: 14px; background: #2a3c78; color: white; border: none; border-radius: 10px; font-size: 15px; font-weight: bold; cursor: pointer; }
        .banner { display: none; position: fixed; top: 70px; left: 50%; transform: translateX(-50%); background: #3c9660; color: white; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: bold; z-index: 999; }
    </style>
</head>
<body>
    <div id="banner" class="banner"></div>

    <div class="header">
        <div style="display:flex;align-items:center;gap:10px">
            <a href="/Settings" class="btn-back">← 戻る</a>
            <div class="header-title">🔑 パスワード変更</div>
        </div>
        <div class="header-nav">
            <a href="/" class="nav-link"><span>🏠</span><small>ホーム</small></a>
            <a href="/Report" class="nav-link"><span>📊</span><small>レポート</small></a>
            <a href="/Settings" class="nav-link"><span>⚙️</span><small>設定</small></a>
        </div>
    </div>

    <div class="container">
        <div class="card">
            <h3>🔑 パスワードを変更する</h3>
            <div class="form-group">
                <label>現在のパスワード</label>
                <input type="password" id="currentPassword" placeholder="現在のパスワード" />
            </div>
            <div class="form-group">
                <label>新しいパスワード（6文字以上）</label>
                <input type="password" id="newPassword" placeholder="新しいパスワード" />
            </div>
            <div class="form-group">
                <label>新しいパスワード（確認）</label>
                <input type="password" id="newPasswordConfirm" placeholder="もう一度入力" />
            </div>
            <button class="btn-save" onclick="changePassword()">💾 変更する</button>
        </div>
    </div>

    <script>
        function showBanner(message) {
            const banner = document.getElementById('banner');
            banner.textContent   = message;
            banner.style.display = 'block';
            setTimeout(() => banner.style.display = 'none', 2000);
        }

        async function changePassword() {
            const current = document.getElementById('currentPassword').value;
            const newPw   = document.getElementById('newPassword').value;
            const confirm = document.getElementById('newPasswordConfirm').value;
            if (!current || !newPw) { alert('全項目を入力してください'); return; }
            if (newPw.length < 6) { alert('新しいパスワードは6文字以上にしてください'); return; }
            if (newPw !== confirm) { alert('新しいパスワードが一致しません'); return; }

            const res  = await fetch('/api/auth/change-password', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ currentPassword: current, newPassword: newPw })
            });
            const json = await res.json();
            if (res.ok) {
                showBanner(json.message);
                setTimeout(() => window.location.href = '/Settings', 1000);
            } else {
                alert(json.message || 'パスワードの変更に失敗しました');
            }
        }
    </script>
</body>
</html>