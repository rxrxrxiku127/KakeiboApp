@page
@model KakeiboApp.Pages.LoginModel
@{
    ViewData["Title"] = "ログイン";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ログイン - 家計簿アプリ</title>
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'メイリオ', sans-serif;
                background: #f0f2f8;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
            }

            .container {
                background: white;
                border-radius: 16px;
                padding: 40px 30px;
                width: 90%;
                max-width: 400px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            }

            .logo {
                text-align: center;
                margin-bottom: 30px;
            }

                .logo h1 {
                    font-size: 28px;
                    color: #2a3c78;
                }

                .logo p {
                    font-size: 13px;
                    color: gray;
                    margin-top: 5px;
                }

            .form-group {
                margin-bottom: 15px;
            }

                .form-group label {
                    display: block;
                    font-size: 12px;
                    font-weight: bold;
                    color: gray;
                    margin-bottom: 6px;
                }

                .form-group input {
                    width: 100%;
                    padding: 12px;
                    border: 1px solid #ddd;
                    border-radius: 8px;
                    font-size: 14px;
                }

                    .form-group input:focus {
                        outline: none;
                        border-color: #2a3c78;
                    }

            .btn-login {
                width: 100%;
                padding: 14px;
                background: #2a3c78;
                color: white;
                border: none;
                border-radius: 10px;
                font-size: 16px;
                font-weight: bold;
                cursor: pointer;
                margin-top: 10px;
            }

                .btn-login:hover {
                    background: #1e2d5a;
                }

            .error {
                background: #fde8e8;
                color: #dc4646;
                padding: 10px 15px;
                border-radius: 8px;
                font-size: 13px;
                margin-bottom: 15px;
            }

            .register-link {
                text-align: center;
                margin-top: 20px;
                font-size: 13px;
                color: gray;
            }

                .register-link a {
                    color: #2a3c78;
                    font-weight: bold;
                    text-decoration: none;
                }

            .divider {
                text-align: center;
                margin: 15px 0;
                color: gray;
                font-size: 12px;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            <h1>💴 家計簿</h1>
            <p>ログインしてはじめよう</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <div class="form-group">
            <label>ユーザーID</label>
            <input type="text" id="userod" placeholder="ユーザーIDを入力" />
        </div>
        <div class="form-group">
            <label>パスワード</label>
            <input type="password" id="password" placeholder="パスワードを入力" />
        </div>

        <button class="btn-login" onclick="login()">ログイン</button>

        <div class="divider">または</div>

        <div class="register-link">
            アカウントをお持ちでない方は
            <a href="/Register">新規登録</a>
        </div>
    </div>

    <script>
            async function login() {
                const userod    = document.getElementById('userod').value.trim();
                const password = document.getElementById('password').value;

                if (!userod || !password) {
                    alert('ユーザーネームとパスワードを入力してください');
                    return;
                }

                const res = await fetch('/api/auth/login', {
                    method  : 'POST',
                    headers : { 'Content-Type': 'application/json' },
                    body    : JSON.stringify({ userod, password })
                });

                if (res.ok) {
                    window.location.href = '/';
                } else {
                    const json = await res.json();
                    alert(json.message || 'ログインに失敗しました');
                }
            }

            // Enterキーでログイン
            document.addEventListener('keydown', e => {
                if (e.key === 'Enter') login();
            });
    </script>
</body>
</html>