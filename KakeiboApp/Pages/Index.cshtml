<div class="transaction-section">
    <h3>📋 今月の取引</h3>
    @if (!Model.AllTransactions.Any())
    {
        <p style="color:gray;font-size:13px">まだ取引がありません</p>
    }
    @foreach (var t in Model.Transactions)
    {
        var cat = Model.GetCategory(t.CategoryId);
        <div class="transaction-item">
            <div class="t-left">
                <div class="t-name">@cat?.Icon @(string.IsNullOrEmpty(t.Note) ? cat?.Name : t.Note)</div>
                <div class="t-meta">@t.Date.ToString("M/d") ・ @Model.GetPaymentLabel(t.PaymentMethod)</div>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
                <div class="t-amount @(t.Type == KakeiboApp.Models.TransactionType.Income ? "income" : "expense")">
                    @(t.Type == KakeiboApp.Models.TransactionType.Income ? "+" : "-")¥@t.Amount.ToString("#,0")
                </div>
                <a href="/Edit?id=@t.Id" class="btn-edit">✏️</a>
                <button class="btn-delete" onclick="deleteTransaction('@t.Id')">🗑</button>
            </div>
        </div>
    }

    @* ページネーション *@
    @if (Model.TotalPages > 1)
    {
        <div style="display:flex;justify-content:center;align-items:center;gap:8px;margin-top:15px;flex-wrap:wrap;">
            @if (Model.CurrentPage > 1)
            {
                <a href="?year=@Model.Year&month=@Model.Month&page=@(Model.CurrentPage - 1)"
                   style="padding:6px 12px;background:#2a3c78;color:white;border-radius:6px;text-decoration:none;font-size:13px;">◀</a>
            }
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a href="?year=@Model.Year&month=@Model.Month&page=@i"
                   style="padding:6px 12px;background:@(i == Model.CurrentPage ? "#2a3c78" : "#eee");color:@(i == Model.CurrentPage ? "white" : "#333");border-radius:6px;text-decoration:none;font-size:13px;">@i</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a href="?year=@Model.Year&month=@Model.Month&page=@(Model.CurrentPage + 1)"
                   style="padding:6px 12px;background:#2a3c78;color:white;border-radius:6px;text-decoration:none;font-size:13px;">▶</a>
            }
        </div>
        <p style="text-align:center;font-size:11px;color:gray;margin-top:8px;">@Model.CurrentPage / @Model.TotalPages ページ（全@Model.AllTransactions.Count件）</p>
    }
</div>