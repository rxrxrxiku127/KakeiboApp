@* ミニカレンダー＋サマリー *@
        <div style="display:flex;gap:15px;margin-bottom:15px;align-items:flex-start;">

            @* ミニカレンダー（一週間分） *@
            <a href="/Calendar?year=@Model.Year&month=@Model.Month"
               style="text-decoration:none;flex-shrink:0;">
                <div style="background:white;border-radius:10px;padding:10px;box-shadow:0 2px 6px rgba(0,0,0,0.08);width:160px;">
                    <div style="font-size:11px;font-weight:bold;color:#2a3c78;text-align:center;margin-bottom:6px;">
                        📅 @Model.Month 月
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;text-align:center;">
                        <div style="font-size:9px;color:#dc4646;">日</div>
                        <div style="font-size:9px;color:gray;">月</div>
                        <div style="font-size:9px;color:gray;">火</div>
                        <div style="font-size:9px;color:gray;">水</div>
                        <div style="font-size:9px;color:gray;">木</div>
                        <div style="font-size:9px;color:gray;">金</div>
                        <div style="font-size:9px;color:#4682dc;">土</div>
                        @{
                            var today = DateTime.Today;
                            var weekStart = today.AddDays(-(int)today.DayOfWeek);
                        }
                        @for (int i = 0; i < 7; i++)
                        {
                            var d = weekStart.AddDays(i);
                            var isToday = d.Date == today;
                            var hasData = Model.AllTransactions.Any(t => t.Date.Date == d.Date);
                            <div style="font-size:10px;font-weight:@(isToday ? "bold" : "normal");
                                        background:@(isToday ? "#2a3c78" : "transparent");
                                        color:@(isToday ? "white" : (i == 0 ? "#dc4646" : i == 6 ? "#4682dc" : "#333"));
                                        border-radius:50%;width:18px;height:18px;
                                        display:flex;align-items:center;justify-content:center;margin:0 auto;">
                                @d.Day
                            </div>
                            @if (hasData)
                            {
                                <div style="font-size:7px;color:#dc4646;text-align:center;">●</div>
                            }
                            else
                            {
                                <div></div>
                            }
                        }
                    </div>
                </div>
            </a>

            @* 収支サマリー *@
            <div class="summary" style="flex:1;margin-bottom:0;">
                <div class="summary-card">
                    <div class="label">収入</div>
                    <div class="amount income">¥@Model.TotalIncome.ToString("#,0")</div>
                </div>
                <div class="summary-card">
                    <div class="label">支出</div>
                    <div class="amount expense">¥@Model.TotalExpense.ToString("#,0")</div>
                </div>
                <div class="summary-card">
                    <div class="label">残高</div>
                    <div class="amount balance">¥@Model.Balance.ToString("#,0")</div>
                </div>
            </div>
        </div>